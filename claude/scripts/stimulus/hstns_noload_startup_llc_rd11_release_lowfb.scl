testbench for "dsPIC33FJ64GS606" is
begin
   -- Keep oscillator lock for firmware init path.
   process is
   begin
      OSCCON.COSC <= "011";
      OSCCON.LOCK <= '1';
      ACLKCON.APLLCK <= '1';
      wait for 1 ic;
   end process;

   -- Startup digital enables:
   --   RD11 high long enough to pass startup gate, then release low.
   process is
   begin
      RD0 <= '1';
      RD11 <= '1';
      RD6 <= '0';
      wait for 30000000 ic;
      RD11 <= '0';
      wait;
   end process;

   -- Fixed non-vout ADC channels (no-load baseline).
   process is
   begin
      ADCBUF1  <= 688;
      ADCBUF3  <= 917;
      ADCBUF4  <= 10;    -- AN4 current sense: no-load
      ADCBUF6  <= 158;
      ADCBUF7  <= 974;
      ADCBUF8  <= 1023;
      ADCBUF9  <= 0;
      ADCBUF10 <= 692;
      ADCBUF11 <= 607;
      ADCBUF12 <= 0;
      ADCBUF13 <= 233;
      ADCBUF14 <= 0;
      ADCBUF15 <= 1019;
      wait;
   end process;

   -- Startup with lower final feedback plateau:
   -- keep AN0/AN2/AN5 below nominal so loop continues pulling frequency.
   process is
   begin
      ADCBUF0 <= 520;
      ADCBUF2 <= 522;
      ADCBUF5 <= 525;
      wait for 150000 ic;

      ADCBUF0 <= 580;
      ADCBUF2 <= 582;
      ADCBUF5 <= 585;
      wait for 150000 ic;

      ADCBUF0 <= 620;
      ADCBUF2 <= 622;
      ADCBUF5 <= 625;
      wait for 150000 ic;

      ADCBUF0 <= 650;
      ADCBUF2 <= 652;
      ADCBUF5 <= 655;
      wait for 150000 ic;

      ADCBUF0 <= 680;
      ADCBUF2 <= 682;
      ADCBUF5 <= 685;
      wait;
   end process;
end testbench;
